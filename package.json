{
	"name": "mushin",
	"version": "1.0.0",
	"description": "GitHub App that automatically merges Dependabot PRs – Cloudflare Worker",
	"private": true,
	"scripts": {
		"dev": "wrangler dev",
		"deploy": "wrangler deploy",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"lint": "npm run typecheck && biome ci",
		"lint:fix": "npm run typecheck && biome check --write",
		"prepare": "lefthook install",
		"release": "semantic-release"
	},
	"dependencies": {
		"fetch-metadata": "github:dependabot/fetch-metadata",
		"yaml": "^2.4.5"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.12",
		"@cloudflare/workers-types": "^4.20241127.0",
		"@commitlint/cli": "^20.5.0",
		"@commitlint/config-conventional": "^20.5.0",
		"@th3s4mur41/release-config": "^2.0.4",
		"@vitest/coverage-v8": "^4.1.4",
		"lefthook": "^2.1.6",
		"semantic-release": "^25.0.3",
		"typescript": "^6.0.3",
		"vitest": "^4.1.4",
		"wrangler": "^4.83.0"
	}
}
